{
  "name": "blockedit",
  "version": "1.2.0",
  "description": "A block-based markdown editor built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^37.2.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2",
    "prettier": "^3.9.5"
  },
  "build": {
    "appId": "com.blockedit.app",
    "productName": "BlockEdit",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.ico"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown document",
        "description": "Markdown document",
        "role": "Editor"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
